{
  "name": "slide-frontend",
  "private": true,
  "version": "0.0.8",
  "description": "Slide messenger desktop client",
  "author": "Slide",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "cross-env VITE_GITHUB_PAGES=1 vite build",
    "preview": "vite preview",
    "build:electron": "cross-env VITE_ELECTRON=1 vite build",
    "electron": "electron .",
    "electron:dev": "cross-env VITE_DEV_HTTPS=1 concurrently \"vite\" \"wait-on https://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:clean": "node scripts/clean-electron-release.cjs",
    "electron:build": "npm run electron:clean && node scripts/build-icon.cjs && npm run build:electron && electron-builder",
    "electron:build:public": "node scripts/bump-electron-version.cjs && npm run electron:build && node scripts/publish-electron-installer.cjs",
    "electron:build:linux": "npm run electron:clean && node scripts/build-icon.cjs && npm run build:electron && electron-builder --linux",
    "electron:start": "npm run build:electron && electron .",
    "build:android": "node scripts/bump-android-version.cjs && node scripts/build-android-icons.cjs && npx @capacitor/assets generate --android --iconBackgroundColor #1a1a2e --assetPath assets && cross-env VITE_CAPACITOR=1 vite build --mode capacitor && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.13.19",
    "canvas-confetti": "^1.9.4",
    "emojilib": "^2.4.0",
    "framer-motion": "^11.11.17",
    "libphonenumber-js": "^1.12.38",
    "lucide-react": "^0.575.0",
    "node-emoji": "^2.2.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "terser": "^5.27.0",
    "to-ico": "^1.1.5",
    "vite": "^5.0.8",
    "vite-plugin-remove-console": "^2.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.slide.messenger",
    "productName": "Slide",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "Slide_Alpha_v${version}.${ext}",
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "sign": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "differentialPackage": false
    }
  }
}
