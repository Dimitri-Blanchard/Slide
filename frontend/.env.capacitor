# Capacitor (Android / iOS) build env.
# api.js hardcodes https://api.sl1de.xyz for native runtime — values here only
# affect things that explicitly read import.meta.env.VITE_*. Do NOT put a LAN
# IP here: it ships into the APK and breaks the app off your home network.
VITE_PUBLIC_SITE_URL=https://sl1de.xyz
VITE_BACKEND_ORIGIN=https://api.sl1de.xyz
VITE_API_BASE_URL=/api
