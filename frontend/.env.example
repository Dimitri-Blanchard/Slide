# Copy to .env or .env.production and adjust for your deployment.
#
# Show the “active development” bottom banner in production builds (staging only).
# Omit or set to false for public releases. In local `npm run dev`, the banner shows by default.
# VITE_SHOW_DEV_BANNER=true
# Vite only exposes variables prefixed with VITE_ to client code.

# Public web app URL (no trailing slash). Used at build time for canonical, Open Graph,
# robots.txt, and sitemap.xml. Defaults to https://slide.app if unset.
# VITE_PUBLIC_SITE_URL=https://your-domain.com

# Backend origin for web builds (no trailing slash). Required when API is on another host.
# VITE_BACKEND_ORIGIN=https://api.your-domain.com

# API base path or full URL. Often left unset so the SPA uses /api on the same origin.
# VITE_API_BASE_URL=/api

# Optional CDN for uploads/avatars (must match backend CDN_BASE_URL when used).
# VITE_CDN_BASE_URL=https://cdn.your-domain.com

# Stripe checkout for Slide Nitro (optional).
# VITE_STRIPE_CHECKOUT_URL=

# Used by some scripts / CI; api.js primarily uses VITE_BACKEND_ORIGIN for web.
# VITE_SERVER_URL=http://localhost:3000
